              "quickstart",
              "architecture-overview"
            ]
          },
          {
            "group": "Product",
            "pages": [
              "using-the-app",
              "verify"
            ]
          },
          {
            "group": "Operators",
            "pages": [
              "run-a-relayer",
              "relayer-registry"
            ]
          },
          {
            "group": "Developers",
            "pages": [
              "sdk",
              "MCP-Server"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/parly-logo.png",
    "dark": "/images/parly-logo-green.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Verify",
