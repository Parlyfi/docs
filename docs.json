  "favicon": "/images/parly-logo-Copy-Copy.png",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "View Relayer Source",
          "href": "https://github.com/Parlyfi/parly-relayer"
        },
        {
